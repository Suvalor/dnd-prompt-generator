# DND Prompt Forge — Docker Compose 环境变量模板
# 复制为 .env 后填写，此文件提交到 git

# ===== 必填 =====
# OpenAI-compatible LLM API 密钥（AI 生成 Prompt 的核心依赖）
LLM_API_KEY=

# ===== 可选 — 有默认值，按需覆盖 =====

# OpenAI-compatible LLM API 地址，例如 https://api.openai.com/v1 或你的兼容服务商 /v1 地址
LLM_BASE_URL=

# LLM 模型名称，由所选兼容服务商决定
LLM_MODEL=

# LLM 最大输出 token（包含 reasoning token；后端默认关闭 thinking）
LLM_MAX_COMPLETION_TOKENS=2048

# LLM 请求超时（秒）
LLM_TIMEOUT_SECONDS=60

# 后端日志级别（DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=INFO

# SQLite 数据库路径（容器内路径，一般不改）
DB_PATH=/app/data/prompt_forge.db

# Session Cookie 签名密钥（生产环境必须设置，留空则每次重启失效）
SESSION_COOKIE_SECRET=

# CSRF 保护密钥（生产环境必须设置，留空则每次重启失效）
CSRF_SECRET=

# Redis 连接地址
REDIS_URL=redis://redis:6379/0

# 是否启用 Redis（true/false）
REDIS_ENABLED=true

# 每用户 LLM 调用配额（次）
LLM_QUOTA_LIMIT=10

# 配额重置窗口（秒，默认 1 小时）
LLM_QUOTA_WINDOW_SECONDS=3600

# 运行环境
APP_ENV=production

# CORS 允许的来源（逗号分隔；本地开发需添加 http://localhost:8081 或设置 APP_ENV=development）
ALLOWED_ORIGINS=https://dndpromptforge.com,https://www.dndpromptforge.com

# ===== 端口映射 =====
FRONTEND_PORT=8081
BACKEND_PORT=8002
