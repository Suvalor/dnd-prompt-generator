# DND Prompt Forge 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ============================================
# 应用环境配置
# ============================================
APP_ENV=production
ALLOWED_ORIGINS=https://dndpromptforge.com,https://www.dndpromptforge.com

# ============================================
# 公共端口配置
# ============================================
FRONTEND_PORT=8081
BACKEND_PORT=8002

# ============================================
# MiMo LLM 配置
# ============================================
MIMO_API_KEY=your_mimo_api_key_here
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5
LLM_TIMEOUT_SECONDS=30

# ============================================
# 配额控制配置
# ============================================
LLM_QUOTA_LIMIT=10
LLM_QUOTA_WINDOW_SECONDS=3600

# ============================================
# 安全配置
# ============================================
SESSION_COOKIE_SECRET=your_session_cookie_secret_here
CSRF_SECRET=your_csrf_secret_here

# ============================================
# Redis 配置
# ============================================
REDIS_URL=redis://redis:6379/0
REDIS_ENABLED=true

# ============================================
# 后端持久化配置
# ============================================
DB_PATH=/app/data/prompt_forge.db
